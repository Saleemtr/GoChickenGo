<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2F2F2F"
    android:orientation="vertical">

    <!-- Top HUD: lives / eggs -->
    <LinearLayout
        android:id="@+id/main_LAY_lives"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#2F2F2F"
        android:gravity="end|center_vertical"
        android:orientation="horizontal"
        android:paddingEnd="18dp">

        <ImageView
            android:id="@+id/main_IMG_life0"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="3dp"
            android:src="@drawable/egg" />

        <ImageView
            android:id="@+id/main_IMG_life1"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="3dp"
            android:src="@drawable/egg" />

        <ImageView
            android:id="@+id/main_IMG_life2"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="3dp"
            android:src="@drawable/egg" />

    </LinearLayout>

    <!-- Game area: road only -->
    <FrameLayout
        android:id="@+id/main_LAY_roadContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#3A3A3A">

        <!-- Lane lines layer -->
        <LinearLayout
            android:id="@+id/main_LAY_laneLines"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <View
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:background="#E0E0E0" />

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <View
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:background="#E0E0E0" />

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

        </LinearLayout>

        <!-- Invisible grid: used only for placing chicken and cars -->
        <GridLayout
            android:id="@+id/main_GRID_road"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:columnCount="3"
            android:rowCount="5"
            android:padding="10dp">

            <!-- Row 0 -->
            <ImageView
                android:id="@+id/main_IMG_cell_0_0"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:padding="18dp"
                android:scaleType="centerInside" />

            <ImageView
                android:id="@+id/main_IMG_cell_0_1"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:padding="18dp"
                android:scaleType="centerInside" />

            <ImageView
                android:id="@+id/main_IMG_cell_0_2"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:padding="18dp"
                android:scaleType="centerInside" />

            <!-- Row 1 -->
            <ImageView
                android:id="@+id/main_IMG_cell_1_0"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:padding="18dp"
                android:scaleType="centerInside" />

            <ImageView
                android:id="@+id/main_IMG_cell_1_1"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:padding="18dp"
                android:scaleType="centerInside" />

            <ImageView
                android:id="@+id/main_IMG_cell_1_2"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:padding="18dp"
                android:scaleType="centerInside" />

            <!-- Row 2 -->
            <ImageView
                android:id="@+id/main_IMG_cell_2_0"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:padding="18dp"
                android:scaleType="centerInside" />

            <ImageView
                android:id="@+id/main_IMG_cell_2_1"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:padding="18dp"
                android:scaleType="centerInside" />

            <ImageView
                android:id="@+id/main_IMG_cell_2_2"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:padding="18dp"
                android:scaleType="centerInside" />

            <!-- Row 3 -->
            <ImageView
                android:id="@+id/main_IMG_cell_3_0"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:padding="18dp"
                android:scaleType="centerInside" />

            <ImageView
                android:id="@+id/main_IMG_cell_3_1"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:padding="18dp"
                android:scaleType="centerInside" />

            <ImageView
                android:id="@+id/main_IMG_cell_3_2"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:padding="18dp"
                android:scaleType="centerInside" />

            <!-- Row 4 -->
            <ImageView
                android:id="@+id/main_IMG_cell_4_0"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:padding="18dp"
                android:scaleType="centerInside" />

            <ImageView
                android:id="@+id/main_IMG_cell_4_1"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:padding="18dp"
                android:scaleType="centerInside" />

            <ImageView
                android:id="@+id/main_IMG_cell_4_2"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:padding="18dp"
                android:scaleType="centerInside" />

        </GridLayout>

        <!-- Hit message -->
        <TextView
            android:id="@+id/main_LBL_hit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="#CC000000"
            android:elevation="30dp"
            android:paddingStart="22dp"
            android:paddingTop="12dp"
            android:paddingEnd="22dp"
            android:paddingBottom="12dp"
            android:text="Oops! Hit!"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Game Over text -->
        <TextView
            android:id="@+id/main_LBL_gameOver"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="#CC000000"
            android:elevation="35dp"
            android:paddingStart="28dp"
            android:paddingTop="18dp"
            android:paddingEnd="28dp"
            android:paddingBottom="18dp"
            android:text="GAME OVER!"
            android:textColor="#FFFFFF"
            android:textSize="44sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Restart button -->
        <Button
            android:id="@+id/main_BTN_restart"
            android:layout_width="170dp"
            android:layout_height="60dp"
            android:layout_gravity="center_horizontal|bottom"
            android:layout_marginBottom="30dp"
            android:backgroundTint="#E91E63"
            android:elevation="35dp"
            android:text="Restart"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Bottom controls: buttons outside the road -->
    <LinearLayout
        android:id="@+id/main_LAY_buttons"
        android:layout_width="match_parent"
        android:layout_height="86dp"
        android:background="#2F2F2F"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="28dp"
        android:paddingEnd="28dp">

        <ImageButton
            android:id="@+id/main_BTN_left"
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:background="@android:color/transparent"
            android:padding="3dp"
            android:scaleType="fitCenter"
            android:src="@drawable/left_arrow" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/main_BTN_right"
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:background="@android:color/transparent"
            android:padding="3dp"
            android:scaleType="fitCenter"
            android:scaleX="-1"
            android:src="@drawable/left_arrow" />

    </LinearLayout>

</LinearLayout>