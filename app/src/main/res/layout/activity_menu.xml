<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/menu_MAIN"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2F2F2F"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <ImageView
        android:id="@+id/menu_IMG_chicken"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/chicken"
        android:scaleType="fitCenter" />

    <TextView
        android:id="@+id/menu_LBL_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="Go Chicken Go!"
        android:textColor="#FFFFFF"
        android:textSize="34sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/menu_LBL_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Choose Game Mode"
        android:textColor="#DDDDDD"
        android:textSize="18sp" />

    <Button
        android:id="@+id/menu_BTN_slow"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_marginTop="30dp"
        android:backgroundTint="#E91E63"
        android:text="Button Mode - Slow"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/menu_BTN_fast"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_marginTop="14dp"
        android:backgroundTint="#E91E63"
        android:text="Button Mode - Fast"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/menu_BTN_sensor"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_marginTop="14dp"
        android:backgroundTint="#E91E63"
        android:text="Sensor Mode"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/menu_BTN_highScores"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_marginTop="26dp"
        android:backgroundTint="#4CAF50"
        android:text="High Scores"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

</LinearLayout>